---
import MainLayout from '../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import fs from 'node:fs';
import path from 'node:path';

const familiasData = await getCollection('familias' as any);
// Ordenar por ID para consistencia
const familias = familiasData.sort((a: any, b: any) => a.data.id - b.data.id);

const getFamilyImage = (filename: string, specialty: string) => {
    const extensions = ['webp', 'png', 'jpg', 'jpeg', 'svg'];
    for (const ext of extensions) {
        const filePath = path.join(process.cwd(), 'public', 'familias', `${filename}.${ext}`);
        if (fs.existsSync(filePath)) return `/familias/${filename}.${ext}`;
    }
    
    // Fallback: imágenes genéricas libres de derechos (Unsplash) según especialidad
    const specLower = specialty.toLowerCase();
    if (specLower.includes('farmaceutica') || specLower.includes('farmacéutica')) {
        return "https://images.unsplash.com/photo-1584308666744-24d5c474f2ae?q=80&w=800&auto=format&fit=crop"; // Laboratorio/Medicina
    }
    if (specLower.includes('alimentacion') || specLower.includes('alimentación')) {
        return "https://images.unsplash.com/photo-1509440159596-0249088772ff?q=80&w=800&auto=format&fit=crop"; // Panadería/Granos
    }
    if (specLower.includes('banca') || specLower.includes('finanzas')) {
        return "https://images.unsplash.com/photo-1501167786227-4cba60f6d58f?q=80&w=800&auto=format&fit=crop"; // Banco
    }
    if (specLower.includes('bienes') || specLower.includes('urbano') || specLower.includes('desarrollo') || specLower.includes('raices') || specLower.includes('raíces')) {
        return "https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?q=80&w=800&auto=format&fit=crop"; // Rascacielos/Desarrollo
    }
    if (specLower.includes('educacion') || specLower.includes('educación')) {
        return "https://images.unsplash.com/photo-1507842217343-583bb7270b66?q=80&w=800&auto=format&fit=crop"; // Biblioteca/Educación
    }
    if (specLower.includes('entretenimiento') || specLower.includes('periodismo')) {
        return "https://images.unsplash.com/photo-1504711434969-e33886168f5c?q=80&w=800&auto=format&fit=crop"; // Prensa/Noticias
    }
    if (specLower.includes('servicios') || specLower.includes('luz') || specLower.includes('agua') || specLower.includes('básicos') || specLower.includes('basicos')) {
        return "https://images.unsplash.com/photo-1473341304170-971dccb5ac1e?q=80&w=800&auto=format&fit=crop"; // Energía/Luz
    }
    return "https://images.unsplash.com/photo-1451187580459-43490279c0fa?q=80&w=800&auto=format&fit=crop"; // Default abstracto/tecnológico
};
---

<MainLayout>
    <div class="min-h-[calc(100vh-4rem)] bg-slate-50/50 flex flex-col justify-between py-12">
        
        <!-- Cabecera Limpia -->
        <div class="text-center max-w-2xl mx-auto pt-8 pb-4 px-6">
            <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-gray-900 mb-4">
                Las 7 Familias
            </h1>
            <div class="w-12 h-1 bg-gray-300 mx-auto rounded-full mb-4"></div>
            <p class="text-base text-gray-500 font-light leading-relaxed">
                Conoce los pilares fundamentales que guían e impulsan el desarrollo de nuestra sociedad.
            </p>
        </div>

        <!-- Contenedor del Carrusel -->
        <div class="relative w-full max-w-4xl mx-auto px-4 md:px-12 flex-1 flex flex-col justify-center my-6">
            
            <!-- Flecha Izquierda -->
            <button id="prev-btn" class="absolute left-0 md:-left-4 top-1/2 -translate-y-1/2 z-30 p-3 bg-white border border-gray-100 rounded-full shadow-md text-gray-400 hover:text-gray-900 hover:shadow-lg transition-all focus:outline-none cursor-pointer" aria-label="Anterior">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
            </button>

            <!-- Ventana del Carrusel -->
            <div class="carousel-viewport overflow-hidden relative w-full rounded-3xl shadow-xl bg-white border border-gray-100/80 min-h-[500px] md:min-h-[400px] flex items-stretch">
                <div class="carousel-track flex w-full transition-transform duration-500 ease-out">
                    {familias.map((f: any) => {
                        const img = getFamilyImage(f.id, f.data.especialidad);
                        return (
                            <div class="carousel-slide w-full flex-shrink-0 flex flex-col md:flex-row items-stretch">
                                <!-- Lado de la Imagen -->
                                <div class="w-full md:w-1/2 min-h-[220px] md:min-h-0 relative overflow-hidden bg-gray-100">
                                    <img src={img} alt={f.data.nombre} class="w-full h-full object-cover transform hover:scale-105 transition-transform duration-700 absolute inset-0" loading="lazy" />
                                    <div class="absolute inset-0 bg-gradient-to-t md:bg-gradient-to-r from-black/10 via-transparent to-transparent"></div>
                                </div>
                                
                                <!-- Lado del Contenido -->
                                <div class="w-full md:w-1/2 p-8 md:p-12 flex flex-col justify-between bg-white">
                                    <div>
                                        <!-- Badge Especialidad -->
                                        <div class="mb-4">
                                            <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold uppercase tracking-wider border" 
                                                  style={`border-color: ${f.data.colorHex}25; color: ${f.data.colorHex}; background-color: ${f.data.colorHex}08;`}>
                                                {f.data.especialidad}
                                            </span>
                                        </div>
                                        
                                        <!-- Nombre de la Familia -->
                                        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4 tracking-tight">
                                            {f.data.nombre}
                                        </h2>
                                        
                                        <!-- Descripción en Cursiva -->
                                        <p class="text-gray-600 text-sm md:text-base leading-relaxed italic font-light">
                                            "{f.data.descripcion}"
                                        </p>
                                    </div>
                                    
                                    <!-- Botón Placeholder -->
                                    <div class="mt-8">
                                        <button class="w-full py-3 px-4 bg-gray-50 border border-gray-200 text-gray-400 rounded-xl text-xs font-semibold uppercase tracking-wider cursor-not-allowed transition-all flex items-center justify-center gap-2" disabled>
                                            Conocer Miembros
                                            <span class="text-[9px] px-1.5 py-0.5 bg-gray-200 border border-gray-300 rounded text-gray-500 font-medium normal-case tracking-normal">Próximamente</span>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        );
                    })}
                </div>
            </div>

            <!-- Flecha Derecha -->
            <button id="next-btn" class="absolute right-0 md:-right-4 top-1/2 -translate-y-1/2 z-30 p-3 bg-white border border-gray-100 rounded-full shadow-md text-gray-400 hover:text-gray-900 hover:shadow-lg transition-all focus:outline-none cursor-pointer" aria-label="Siguiente">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
            </button>

        </div>

        <!-- Indicadores (dots) -->
        <div class="flex justify-center gap-3 pb-8">
            {familias.map((f: any, idx: number) => (
                <button class="carousel-dot w-2.5 h-2.5 rounded-full bg-gray-200 hover:bg-gray-400 transition-all focus:outline-none cursor-pointer" data-index={idx} style={`--active-color: ${f.data.colorHex}`} aria-label={`Ir a familia ${idx + 1}`}></button>
            ))}
        </div>

    </div>

    <!-- Script de Interactividad -->
    <script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
            const track = document.querySelector('.carousel-track');
            const slides = document.querySelectorAll('.carousel-slide');
            const prevBtn = document.getElementById('prev-btn');
            const nextBtn = document.getElementById('next-btn');
            const dots = document.querySelectorAll('.carousel-dot');

            if (!track || slides.length === 0) return;

            let currentIndex = 0;

            function updateCarousel(index) {
                if (index < 0) index = slides.length - 1;
                if (index >= slides.length) index = 0;
                currentIndex = index;
                
                // Mover el contenedor
                track.style.transform = `translateX(-${currentIndex * 100}%)`;
                
                // Actualizar los indicadores
                dots.forEach((dot, idx) => {
                    if (idx === currentIndex) {
                        const activeColor = dot.style.getPropertyValue('--active-color') || '#1f2937';
                        dot.style.backgroundColor = activeColor;
                        dot.classList.add('scale-125');
                        dot.classList.remove('bg-gray-200');
                    } else {
                        dot.style.backgroundColor = '';
                        dot.classList.remove('scale-125');
                        dot.classList.add('bg-gray-200');
                    }
                });
            }

            // Inicializar
            updateCarousel(0);

            // Eventos
            if (prevBtn) prevBtn.addEventListener('click', () => updateCarousel(currentIndex - 1));
            if (nextBtn) nextBtn.addEventListener('click', () => updateCarousel(currentIndex + 1));
            
            dots.forEach(dot => {
                dot.addEventListener('click', () => {
                    const idx = parseInt(dot.getAttribute('data-index') || '0', 10);
                    updateCarousel(idx);
                });
            });

            // Soporte para gestos táctiles (Swipe)
            let startX = 0;
            let isSwiping = false;

            track.addEventListener('touchstart', (e) => {
                startX = e.touches[0].clientX;
                isSwiping = true;
            }, { passive: true });

            track.addEventListener('touchmove', (e) => {
                if (!isSwiping) return;
                const diff = e.touches[0].clientX - startX;
                if (Math.abs(diff) > 50) {
                    if (diff > 0) {
                        updateCarousel(currentIndex - 1);
                    } else {
                        updateCarousel(currentIndex + 1);
                    }
                    isSwiping = false;
                }
            }, { passive: true });

            track.addEventListener('touchend', () => {
                isSwiping = false;
            });
        });
    </script>
</MainLayout>

<style>
    .carousel-slide {
        width: 100%;
        flex-shrink: 0;
    }
    .carousel-track {
        display: flex;
        width: 100%;
        transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }
</style>